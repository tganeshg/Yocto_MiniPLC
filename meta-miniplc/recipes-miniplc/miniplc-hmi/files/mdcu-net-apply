#!/bin/sh
# /usr/bin/mdcu-net-apply
#
# Reads /etc/mdcu/network.conf, regenerates /etc/network/interfaces, and
# restarts the configured interface.  Owned by the MiniHMI app — the HMI
# writes network.conf and then runs this script as root.
#
# Config file format (key=value, one per line):
#   mode=dhcp        # or "static"
#   iface=eth0
#   address=192.168.1.50    # static only
#   netmask=255.255.255.0
#   gateway=192.168.1.1
#   dns1=8.8.8.8
#   dns2=1.1.1.1
#
set -e

CONF=/etc/mdcu/network.conf
INTERFACES=/etc/network/interfaces
RESOLV=/etc/resolv.conf

# defaults
mode=dhcp
iface=eth0
address=
netmask=
gateway=
dns1=
dns2=

if [ -r "$CONF" ]; then
    # shellcheck disable=SC1090
    . "$CONF"
fi

# Sanitize: only allow simple alnum / dot / dash in shell-derived values
sanitize() { echo "$1" | tr -cd 'A-Za-z0-9._-'; }
iface=$(sanitize "$iface")
[ -z "$iface" ] && iface=eth0

# Write /etc/network/interfaces atomically
TMP=$(mktemp)
{
    echo "# Auto-generated by mdcu-net-apply — do not edit by hand."
    echo "auto lo"
    echo "iface lo inet loopback"
    echo ""
    echo "auto $iface"
    if [ "$mode" = "static" ]; then
        echo "iface $iface inet static"
        [ -n "$address" ] && echo "    address $(sanitize "$address")"
        [ -n "$netmask" ] && echo "    netmask $(sanitize "$netmask")"
        [ -n "$gateway" ] && echo "    gateway $(sanitize "$gateway")"
    else
        echo "iface $iface inet dhcp"
    fi
} > "$TMP"
mv "$TMP" "$INTERFACES"

# Resolv.conf for static DNS only — dhcpcd manages it for DHCP mode
if [ "$mode" = "static" ]; then
    TMP=$(mktemp)
    {
        echo "# Auto-generated by mdcu-net-apply"
        [ -n "$dns1" ] && echo "nameserver $(sanitize "$dns1")"
        [ -n "$dns2" ] && echo "nameserver $(sanitize "$dns2")"
    } > "$TMP"
    mv "$TMP" "$RESOLV"
fi

# Restart the interface.  Try ifdown/ifup; fall back to ip link cycle.
if command -v ifdown >/dev/null 2>&1 && command -v ifup >/dev/null 2>&1; then
    ifdown "$iface" 2>/dev/null || true
    ifup   "$iface"
else
    ip link set "$iface" down 2>/dev/null || true
    ip link set "$iface" up
fi

logger -t mdcu-net-apply "applied $mode config on $iface"
echo "mdcu-net-apply: $mode config applied on $iface"
